# ============================================
# ENVIRONMENT VARIABLES - COPIAR Y RELLENAR
# ============================================
# Copiar este archivo a .env y llenar con valores reales
# NO VERSIONAR EL ARCHIVO .env CON DATOS REALES

# DATABASE
DB_URL=jdbc:mysql://localhost:3306/microfarmahorarios?zeroDateTimeBehavior=convertToNull
DB_USERNAME=root
DB_PASSWORD=tu_password_super_seguro

# SERVER
SERVER_PORT=8082

# JWT - GENERAR CLAVE SEGURA
# Ejecutar: openssl rand -hex 128
JWT_SECRET=tu_clave_jwt_de_256_caracteres_minimo_muy_larga_y_aleatoria_aqui
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# EMAIL (Gmail con App Passwords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password_16_caracteres

# ENVIRONMENT
SPRING_PROFILES_ACTIVE=prod
